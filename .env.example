# SUPABASE CONFIGURATION (Frontend - Public)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# SUPABASE CONFIGURATION (Backend/Serverless - Secret, DO NOT expose to frontend)
# Only set this in Vercel Environment Variables for serverless functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# BREVO EMAIL OTP
VITE_BREVO_API_KEY=your-brevo-api-key

# APP CONFIGURATION
VITE_APP_NAME=Chettiar Connect
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173

# STORAGE
VITE_STORAGE_URL=https://your-project.supabase.co/storage/v1/object/public
